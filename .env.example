PORT=8787
VITE_DEV_ORIGIN=http://localhost:5173
VITE_TIRTC_ENV=test
TIRTC_ACCESS_KEY_ID=your_access_key_id
TIRTC_SECRET_KEY_ID=your_secret_key_id
TIRTC_APP_ID=your_app_id
TIRTC_ENDPOINT=http://ep-test-tirtc.tange365.com
TIRTC_OPENAPI_ENDPOINT=http://api-test-tirtc.tange365.com
ENABLE_DEVICE_DEBUG=0

# Optional tuning
TIRTC_CLIENT_UID=uid1
TIRTC_USER_TOKEN_TTL=36000
TIRTC_CHANNEL_TOKEN_TTL=36000

# Vercel deployment requires at least:
# VITE_TIRTC_ENV
# TIRTC_ACCESS_KEY_ID
# TIRTC_SECRET_KEY_ID
# TIRTC_APP_ID
# TIRTC_ENDPOINT
# TIRTC_OPENAPI_ENDPOINT
# ENABLE_DEVICE_DEBUG
